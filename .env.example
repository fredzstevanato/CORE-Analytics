NODE_ENV=development

# Database
POSTGRES_USER=core
POSTGRES_PASSWORD=core
POSTGRES_DB=core_analytics
DATABASE_URL=postgresql://core:core@localhost:5432/core_analytics?schema=public

# Queue
REDIS_URL=redis://localhost:6379

# Search
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=Core@2026!Strong

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT=D:/CORE-Analytics-storage
UFDR_SOURCE_ROOT=D:/CORE-Analytics-ufdr-imports
# Linux local restore example:
# STORAGE_ROOT=/home/fredz/Documentos/CORE-Analytics-storage
# UFDR_SOURCE_ROOT=/home/fredz/Documentos/CORE-Analytics-storage/evidences

# Optional MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=core-evidence
MINIO_USE_SSL=false

# App
CORE_IMAGE=core-analytics:local
CORE_BACKUP_DIR=./backups
# Absolute path to the folder containing docker-compose.yml on the HOST.
# Required when the web container needs to manage Docker (Settings > Updates).
# Windows example: COMPOSE_WORKDIR=C:/Users/steva/Desktop/core-analytics-releases/CORE-Analytics-transfer-windows-20260708
# Linux example:   COMPOSE_WORKDIR=/opt/core-analytics
COMPOSE_WORKDIR=
NEXT_PUBLIC_APP_NAME=CORE Analytics
APP_BASE_URL=http://localhost:3001
MOCK_USER_EMAIL=analista@core.local
MOCK_USER_PASSWORD=Admin@123
SESSION_SECRET=change-me-super-secret
SETTINGS_ENCRYPTION_KEY=change-me-settings-secret

# Whisper local
WHISPER_BIN=whisper
WHISPER_MODEL=base
WHISPER_MODEL_DIR=D:/CORE-Analytics-storage/models/whisper
FFMPEG_BIN=ffmpeg
TESSERACT_BIN=tesseract
SEVEN_Z_BIN=7z

# PDF OCR portable (project-local)
PDF_OCR_COMMAND=powershell
PDF_OCR_COMMAND_ARGS=-NoProfile -ExecutionPolicy Bypass -File {projectRoot}/scripts/ocrmypdf-portable.ps1 -InputFile {input} -OutputFile {output} -Pages {pages} -Language {lang}
PDF_OCR_LANGUAGE=por+eng
PDF_PROCESSING_DEBUG=false

REPORT_XML_MAX_BYTES=1073741824
REPORT_XML_MAX_STRING_BYTES=805306368
# UFDR parser sem limites (deixe comentado para não truncar dados)
# UFDR_PARSER_MAX_CHATS=
# UFDR_PARSER_MAX_MESSAGES_PER_CHAT=
# UFDR_PARSER_MAX_TOTAL_MESSAGES=
# UFDR_PARSER_MAX_AUDIO_FILES=
# Optional hard caps (leave commented for unlimited processing)
# UFDR_AUDIO_MAX_FILES=
# UFDR_AUDIO_EXTRACTION_TIMEOUT_MS=900000
# UFDR_FORCE_XML_STREAM=true
# UFDR_XML_STREAM_MIN_FILES=20000
# UFDR_XML_IN_MEMORY_MAX_CHARS=8000000
# Opcional: timeout da extracao de audio (ms). Vazio/0/desligado = sem limite.
# UFDR_STALE_PROCESSING_TIMEOUT_MS=2700000
# UFDR_STALE_WATCHDOG_INTERVAL_MS=120000
# WORKER_LOG_HEARTBEAT_SECONDS=30
# WORKER_INGEST_DEBUG_PHASES=false
# WORKER_LOG_LEVEL=info
# WORKER_INGEST_LOG_LEVEL=info
# AI_TRANSCRIPTION_WORKER_CONCURRENCY=8
# AI_TRANSCRIPTION_LOCK_DURATION_SECONDS=120
# AI_TRANSCRIPTION_STALLED_INTERVAL_SECONDS=30
# AI_TRANSCRIPTION_MAX_STALLED_COUNT=3
# AI_TRANSCRIPTION_STALE_PROCESSING_SECONDS=240

# Sincronizacao consolidada entre maquinas. O centralizador tambem continua extraindo UFDR localmente,
# mas recebe de outros nodes apenas dados selecionados e consolidados, nunca UFDR bruto.
APP_NODE_ROLE=STANDALONE
# SYNC_NODE_ID=maquina-pericia-01
# SYNC_NODE_NAME=Maquina Pericia 01
# CENTRALIZER_URL=http://centralizador.local:3001
# SYNC_API_TOKEN=change-me
# SYNC_PACKAGE_MAX_FILE_BYTES=26214400
# WORKER_AI_LOG_LEVEL=info
# UFDR_PERSIST_MAX_CHATS=
# UFDR_PERSIST_MAX_PARTICIPANTS_PER_CHAT=
# UFDR_PERSIST_MAX_MESSAGES_PER_CHAT=
# UFDR_PERSIST_MAX_CONTACTS=
# UFDR_PERSIST_MAX_CALLS=
# UFDR_PERSIST_MAX_FILES=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CASE_CONTEXT_MODEL=gpt-5.4
OPENAI_INVESTIGATION_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_INVESTIGATION_REPORT_MODEL=gpt-5.4

CORE_HUB_BASE_URL=http://localhost:4010
CORE_HUB_API_TOKEN=change-me
CORE_HUB_EXPORT_ENABLED=false
CORE_HUB_EXPORT_TIMEOUT_MS=15000
CORE_HUB_EXPORT_RETRY_MAX=3
CORE_HUB_DELETE_UFDR_AFTER_SYNC=false

