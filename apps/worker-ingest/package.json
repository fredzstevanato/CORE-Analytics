  "dependencies": {
    "@core/cases": "*",
    "@core/db": "*",
    "@core/parsers": "*",
    "@core/queue": "*",
    "@core/search": "*",
    "@core/shared": "*",
    "bullmq": "^5.47.2",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
