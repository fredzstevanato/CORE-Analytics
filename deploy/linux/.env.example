CORE_IMAGE=ghcr.io/YOUR_USER_OR_ORG/YOUR_REPO:latest

POSTGRES_USER=core
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=core_analytics

OPENSEARCH_PASSWORD=replace-with-a-strong-password

SESSION_SECRET=replace-with-a-long-random-secret
SETTINGS_ENCRYPTION_KEY=replace-with-a-long-random-secret

WEB_PORT=3001
UFDR_SOURCE_ROOT=/mnt/evidencias
WATCHTOWER_INTERVAL_SECONDS=300

APP_NODE_ROLE=STANDALONE
SYNC_NODE_ID=linux-production-node
SYNC_NODE_NAME=Linux Production Node
SYNC_API_TOKEN=replace-if-using-sync

AI_TRANSCRIPTION_WORKER_CONCURRENCY=2
UFDR_AUDIO_RECOVERY_WORKER_CONCURRENCY=4
